# proto-file: proto/rules/v1/rules.proto
# proto-message: rules.v1.RuleSet

# Default built-in command rules for cc-permission-handler.
# Activated when a project specifies use_default_rules.

# ============================================================================
# Always-safe commands (safe with any arguments)
# ============================================================================

# Filesystem inspection
commands {
  names: ["cat", "head", "tail", "less", "more", "bat"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["ls", "tree", "exa", "eza"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["file", "stat", "du", "df"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: "pwd"
  custom_rules {
    rules { always_allow {} }
  }
}

# Text processing
commands {
  names: ["echo", "printf"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["grep", "egrep", "fgrep", "rg", "ag", "ack"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["wc", "uniq", "cut", "tr", "rev", "tac"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["diff", "cmp", "comm", "colordiff", "delta"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["column", "expand", "fold", "fmt", "nl", "paste", "join"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Search / locate
commands {
  names: ["locate", "mdfind"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Path utilities
commands {
  names: ["basename", "dirname", "realpath", "readlink"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Checksums
commands {
  names: ["md5sum", "sha256sum", "sha1sum", "shasum", "md5"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Env / identity
commands {
  names: "printenv"
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["uname", "hostname"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["id", "whoami", "groups"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["date", "cal"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Structured data
commands {
  names: "jq"
  custom_rules {
    rules { always_allow {} }
  }
}

# Shell builtins / trivial
commands {
  names: ["cd", "pushd", "popd", "true", "false", "test"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: "["  # test builtin (parsed as a command by mvdan/sh)
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["which", "whereis", "type", "hash"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["seq", "mktemp", "sleep"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["export", "set"]
  custom_rules {
    rules { always_allow {} }
  }
}

# System info (read-only)
commands {
  names: ["top", "ps", "uptime", "free"]
  custom_rules {
    rules { always_allow {} }
  }
}

# Build tools
commands {
  names: ["agent-bzl", "bazel", "bzl", "mbzl"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: "rustc"
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["tsc", "eslint", "prettier"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: ["black", "isort", "flake8", "mypy", "pylint", "ruff"]
  custom_rules {
    rules { always_allow {} }
  }
}
commands {
  names: "shellcheck"
  custom_rules {
    rules { always_allow {} }
  }
}

# ============================================================================
# Flag-checked commands
# ============================================================================

# sort: -o/--output arg is a write target
commands {
  names: "sort"
  custom_rules {
    rules {
      allow {
        condition {
          flag_arg_check {
            names: ["-o", "--output"]
            has_arg: true
            check { write_check {} }
          }
        }
      }
    }
  }
}

# yq: deny if -i/--in-place present
commands {
  names: "yq"
  custom_rules {
    rules {
      allow {
        condition {
          not {
            condition {
              has_flag_matching {
                pattern { short_chars: "i"  long_prefixes: "--in-place" }
              }
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# Bare-command-only
# ============================================================================

commands {
  names: "env"
  custom_rules {
    rules { allow { condition { no_args {} } } }
  }
}

# ============================================================================
# Flag-presence-gated
# ============================================================================

commands {
  names: "command"
  custom_rules {
    rules {
      allow {
        condition {
          has_flag_matching { exact { flags: ["-v", "-V"] } }
        }
      }
    }
  }
}

# ============================================================================
# Subcommand allowlists
# ============================================================================

commands {
  names: "gh"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            allowed_with_any_args: [
              "pr", "issue", "repo", "api", "dbx",
              "run", "workflow", "release", "gist",
              "auth", "config", "status",
              "browse", "codespace", "label", "project"
            ]
          }
        }
      }
    }
  }
}

commands {
  names: "cargo"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            allowed_with_any_args: [
              "build", "test", "bench", "run", "check", "clean", "doc",
              "new", "init", "add", "remove", "fetch", "update", "search",
              "publish", "install", "uninstall", "fix", "clippy", "fmt",
              "tree", "version", "metadata"
            ]
          }
        }
      }
    }
  }
}

commands {
