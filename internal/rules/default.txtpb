}

# ============================================================================
# Builtins (marker types — logic implemented in Go)
# ============================================================================

commands {
  names: ["sed", "gsed"]
  sed_checker {}
}

commands {
  names: ["awk", "gawk", "mawk", "nawk"]
  awk_checker {}
}
