# ============================================================================
# Path write commands
# ============================================================================

commands {
  names: ["cp", "mv", "rm", "mkdir", "touch", "tee"]
  custom_rules {
    rules {
      allow {
        condition {
          flag_arg_check {
            names: ["-t", "--target-directory"]
            has_arg: true
            check { write_check {} }
          }
        }
      }
    }
    rules {
      allow {
        condition {
          every_positional_passes { check { write_check {} } }
        }
      }
    }
    require_cwd: true
  }
}

# ============================================================================
# Flag-allowlist commands (find, fd)
# ============================================================================

commands {
  names: "find"
  custom_rules {
    rules {
      allow {
        condition {
          every_flag_matches {
            allowed_without_args: [
              "-print", "-print0", "-prune", "-depth", "-empty",
              "-daystart", "-xdev", "-mount", "-follow", "-noleaf",
              "-true", "-false",
              "-readable", "-writable", "-executable",
              "-not", "-and", "-or"
            ]
            allowed_with_args: [
              "-name", "-iname", "-path", "-ipath",
              "-wholename", "-iwholename",
              "-type", "-xtype",
              "-maxdepth", "-mindepth",
              "-mtime", "-atime", "-ctime",
              "-mmin", "-amin", "-cmin",
              "-newer",
              "-size", "-perm",
              "-regex", "-iregex", "-regextype",
              "-user", "-group", "-uid", "-gid",
              "-samefile", "-links", "-inum",
              "-printf"
            ]
          }
        }
      }
    }
  }
}

commands {
  names: ["fd", "fdfind"]
  custom_rules {
    rules {
      allow {
        condition {
          every_flag_matches {
            allowed_without_args: [
              "-H", "--hidden",
              "-I", "--no-ignore",
              "--no-ignore-vcs", "--no-ignore-parent",
              "-s", "--case-sensitive",
              "-i", "--ignore-case",
              "-g", "--glob",
              "-F", "--fixed-strings",
              "-a", "--absolute-path",
              "-l", "--list-details",
              "-L", "--follow",
              "-p", "--full-path",
              "-0", "--print0",
              "--strip-cwd-prefix",
              "-u", "--unrestricted",
              "--one-file-system",
              "--prune",
              "-q", "--quiet"
            ]
            allowed_with_args: [
              "-d", "--max-depth",
              "--min-depth",
              "-t", "--type",
              "-e", "--extension",
              "-E", "--exclude",
              "-c", "--color",
              "-j", "--threads",
              "-S", "--size",
              "--changed-within", "--changed-before",
              "--max-results",
              "--base-directory",
              "--path-separator",
              "--search-path"
            ]
          }
        }
      }
    }
  }
}

# ============================================================================
# git
# ============================================================================

commands {
  names: "git"
  custom_rules {
    # Global flags that take an argument (so the parser consumes them correctly).
    rules {
      allow {
        condition {
          flag_arg_check {
            names: ["-C", "--git-dir", "--work-tree", "--namespace"]
            has_arg: true
          }
        }
      }
    }
    rules {
      deny {
        condition {
          has_flag_matching { exact { flags: ["-c", "--config-env"] } }
        }
      }
    }
    rules { deny { condition { has_double_dash {} } } }
    rules {
      allow {
        condition {
          subcommands {
            allowed_with_any_args: [
              "status", "log", "diff", "show", "branch", "tag",
              "stash", "add", "commit", "fetch", "pull", "push",
              "checkout", "switch", "restore", "merge", "rebase",
              "remote", "rev-parse", "ls-files", "ls-tree",
              "blame", "shortlog", "describe", "name-rev",
              "config", "worktree", "submodule", "cherry-pick",
              "clean", "reset", "mv", "rm", "init", "clone"
            ]
          }
        }
      }
    }
  }
}

# ============================================================================
# go
# ============================================================================

commands {
  names: "go"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            allowed_with_any_args: [
              "build", "test", "vet", "fmt", "mod", "get", "install",
              "clean", "env", "version", "list", "doc", "work", "tool",
              "generate"
            ]
            with_rules {
              names: "run"
              custom_rules {
                rules {
                  allow {
                    condition {
                      every_positional_passes { check { write_check {} } }
                    }
                  }
                }
                require_cwd: true
              }
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# ssh / tsh
# ============================================================================

commands {
  names: "ssh"
  custom_rules {
    rules {
      allow {
        condition {
          every_flag_matches {
            allowed_without_args: [
              "-t", "-n", "-N", "-q", "-v",
              "-A", "-a", "-4", "-6"
            ]
            allowed_with_args: ["-i", "-l", "-p", "-L", "-R"]
          }
        }
      }
    }
    rules {
      allow {
        condition {
          every_positional_passes { check { ssh_remote_eval {} } }
        }
      }
    }
    support_combined_short_flags: true
  }
}

commands {
  names: "tsh"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            with_rules {
              names: "ssh"
              ref_command_spec: "ssh"
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# terraform
# ============================================================================

commands {
  names: "terraform"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            allowed_with_any_args: [
              "init", "validate", "plan", "fmt", "show", "output",
              "version", "providers", "graph"
            ]
            with_rules {
              names: ["state", "workspace"]
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: ["list", "show", "select"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# terragrunt
# ============================================================================

commands {
  names: "terragrunt"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            # OpenTofu/Terraform pass-through (safe subset, mirrors terraform rules).
            allowed_with_any_args: [
              "init", "validate", "plan", "fmt",
              "show", "output", "version", "providers", "graph"
            ]
            # Terragrunt-native read-only / safe commands.
            allowed_with_any_args: [
              "catalog", "scaffold", "find", "list", "render"
            ]
            with_rules {
              names: ["state", "workspace"]
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: ["list", "show", "select"]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "stack"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: ["output", "generate"]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "hcl"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: ["fmt", "validate"]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "dag"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands { allowed_with_any_args: "graph" }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "info"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: ["print", "strict"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# aws (curated safe read-only operations)
# ============================================================================

commands {
  names: "aws"
  custom_rules {
    rules {
      allow {
        condition {
          subcommands {
            with_rules {
              names: "sts"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "get-caller-identity", "get-session-token",
                          "get-access-key-info"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "s3"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands { allowed_with_any_args: "ls" }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "s3api"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "list-buckets", "list-objects", "list-objects-v2",
                          "get-bucket-location", "head-object", "head-bucket"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "ec2"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "describe-instances", "describe-vpcs", "describe-subnets",
                          "describe-security-groups", "describe-images",
                          "describe-regions", "describe-availability-zones"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "iam"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "get-user", "get-role", "get-policy",
                          "list-users", "list-roles", "list-policies",
                          "list-attached-role-policies", "list-attached-user-policies"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "lambda"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "list-functions", "get-function", "get-function-configuration"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "cloudformation"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "describe-stacks", "list-stacks", "describe-stack-resources",
                          "validate-template", "get-template"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "logs"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands {
                        allowed_with_any_args: [
                          "describe-log-groups", "get-log-events", "filter-log-events"
                        ]
                      }
                    }
                  }
                }
              }
            }
            with_rules {
              names: "configure"
              custom_rules {
                rules {
                  allow {
                    condition {
                      subcommands { allowed_with_any_args: ["list", "get"] }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

# ============================================================================
# buf / protoc
